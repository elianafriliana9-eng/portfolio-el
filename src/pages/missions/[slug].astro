---
import { render } from 'astro:content';

import EntryLayout from '../../layouts/EntryLayout.astro';
import { getMissionEntries } from '../../lib/content';

export async function getStaticPaths() {
  const missions = await getMissionEntries();
  return missions.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<EntryLayout
  title={entry.data.title}
  eyebrow="Work Experience"
  summary={entry.data.summary}
  image={entry.data.coverImage}
  backHref="/missions/"
  backLabel="All experience"
  details={[
    { label: 'Status', value: entry.data.status },
    { label: 'Location', value: entry.data.destination },
    { label: 'Role / Tech Stack', value: entry.data.vehicle },
    { label: 'Duration', value: entry.data.missionWindow },
  ]}
>
  <Content />
</EntryLayout>
