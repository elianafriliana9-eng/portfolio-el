---
import DepartureSection from '../components/DepartureSection';
import DiscoverySection from '../components/DiscoverySection';
import FooterSection from '../components/FooterSection';
import HeroShell from '../components/HeroShell';
import MissionsSection from '../components/MissionsSection';
import StatsSection from '../components/StatsSection';
import {
  footerDirectory,
  footerMeta,
  footerPolicies,
  heroContent,
  heroLeftNav,
  heroRightNav,
  mobileNav,
  stats,
} from '../data/site';
import {
  getDepartureEntries,
  getMissionEntries,
  getReportEntries,
  toDiscoveryContent,
  toLaunchRow,
  toMissionCard,
  toNextDepartureContent,
  toSpectrumBars,
} from '../lib/content';
import '../styles/global.css';

const [missionEntries, reportEntries, departureEntries] = await Promise.all([
  getMissionEntries(),
  getReportEntries(),
  getDepartureEntries(),
]);

const featuredReport = reportEntries[0];
const featuredDeparture = departureEntries[0];
---

<html lang="en" class="bg-page-bg">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Portfolio of Elian Afrilina, SE - IT System Developer and Creative Designer based in Tangerang."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700;800;900&family=Space+Grotesk:wght@300;400;500;700&display=swap"
    />
    <script is:inline>
      (() => {
        const key = 'aeon-theme';
        const stored = window.localStorage.getItem(key);
        const theme = stored === 'light' || stored === 'dark' ? stored : 'dark';
        document.documentElement.dataset.theme = theme;
        document.documentElement.classList.toggle('dark', theme === 'dark');
      })();
    </script>
    <title>Elian Afrilina - Portfolio</title>
  </head>
  <body class="bg-page-bg font-body text-white antialiased">
    <main class="site-shell overflow-x-clip">
      <HeroShell
        client:load
        content={heroContent}
        leftNav={heroLeftNav}
        mobileNav={mobileNav}
        rightNav={heroRightNav}
      />
      <MissionsSection client:visible missions={missionEntries.map(toMissionCard)} />
      {featuredReport ? (
        <DiscoverySection
          client:visible
          bars={toSpectrumBars(featuredReport)}
          content={toDiscoveryContent(featuredReport)}
        />
      ) : null}
      <StatsSection client:visible stats={stats} />
      {featuredDeparture ? (
        <DepartureSection
          client:visible
          content={toNextDepartureContent(featuredDeparture)}
          launches={departureEntries.map(toLaunchRow)}
        />
      ) : null}
      <FooterSection
        client:visible
        directory={footerDirectory}
        meta={footerMeta}
        policies={footerPolicies}
      />
    </main>
  </body>
</html>
