---
import CollectionIndexLayout from '../../layouts/CollectionIndexLayout.astro';
import { formatLongDate } from '../../lib/format';
import { getReportEntries } from '../../lib/content';

const reports = await getReportEntries();
---

<CollectionIndexLayout
  title="Education"
  eyebrow="Academic Background"
  intro="My educational background and academic journey."
  description="Browse my educational background."
>
  <div class="grid gap-6 lg:grid-cols-2">
    {reports.map((report) => (
      <a
        href={`/reports/${report.id}/`}
        class="group grid overflow-hidden border border-white/10 bg-white/3 transition-colors duration-300 hover:border-accent-blue/50 md:grid-cols-[220px_minmax(0,1fr)]"
      >
        <img src={report.data.image} alt={report.data.title} class="aspect-[4/3] h-full w-full object-cover md:aspect-auto" />
        <div class="p-7 sm:p-8">
          <div class="flex flex-wrap items-center gap-3 text-sm text-white/48">
            <span class="font-display text-[10px] uppercase tracking-[0.24em] text-warm-gold">{report.data.label}</span>
            <span>•</span>
            <span>{formatLongDate(report.data.publishedAt)}</span>
          </div>
          <h2 class="mt-5 break-words font-display text-[2rem] leading-none text-white">{report.data.title}</h2>
          <p class="mt-5 text-[1.02rem] leading-8 text-white/68">{report.data.summary}</p>
          <div class="mt-8 font-display text-[10px] uppercase tracking-[0.24em] text-accent-blue">{report.data.highlight}</div>
          <span class="mt-8 inline-flex items-center gap-3 font-display text-[11px] uppercase tracking-[0.24em] text-white/55 transition-colors duration-300 group-hover:text-accent-blue">
            View details <span aria-hidden="true">→</span>
          </span>
        </div>
      </a>
    ))}
  </div>
</CollectionIndexLayout>
