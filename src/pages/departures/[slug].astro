---
import { render } from 'astro:content';

import LaunchCountdown from '../../components/LaunchCountdown';
import EntryLayout from '../../layouts/EntryLayout.astro';
import { getDepartureEntries } from '../../lib/content';
import { formatLaunchTime, formatLongDate, toUtcDateInput } from '../../lib/format';

export async function getStaticPaths() {
  const departures = await getDepartureEntries();
  return departures.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<EntryLayout
  title={entry.data.title}
  eyebrow="Skill Details"
  summary={entry.data.detail}
  image={entry.data.image}
  backHref="/departures/"
  backLabel="All skills"
  details={[
    { label: 'Date Acquired', value: formatLongDate(entry.data.launchDate) },
    { label: 'Category', value: entry.data.launchSite },
    { label: 'Proficiency Level', value: entry.data.missionWindow },
  ]}
>
  <div class="mb-10 border border-white/10 bg-white/[0.03] p-6 sm:p-7">
    <div class="font-display text-[10px] uppercase tracking-[0.24em] text-accent-blue">Active Since</div>
    <LaunchCountdown
      client:load
      launchDate={toUtcDateInput(entry.data.launchDate)}
      launchTime={entry.data.launchTime}
      className="mt-4 block font-display text-4xl leading-none text-white sm:text-5xl"
    />
  </div>
  <Content />
</EntryLayout>
