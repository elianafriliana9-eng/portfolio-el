---
import SiteLayout from './SiteLayout.astro';

interface DetailItem {
  label: string;
  value: string;
}

interface Props {
  backHref: string;
  backLabel: string;
  description?: string;
  details?: DetailItem[];
  eyebrow: string;
  image?: string;
  summary: string;
  title: string;
}

const {
  backHref,
  backLabel,
  description,
  details = [],
  eyebrow,
  image,
  summary,
  title,
} = Astro.props;
---

<SiteLayout title={`${title} | Elian's Portfolio`} description={description ?? summary}>
  <main class="mx-auto max-w-7xl px-6 py-16 sm:px-8 sm:py-20 lg:px-12 lg:py-24">
    <a
      href={backHref}
      class="inline-flex items-center gap-3 font-display text-[11px] uppercase tracking-[0.26em] text-white/56 transition-colors duration-300 hover:text-accent-blue"
    >
      <span aria-hidden="true">←</span>
      {backLabel}
    </a>

    <section class={`mt-8 grid gap-10 ${image ? 'lg:grid-cols-[minmax(0,1.05fr)_420px] lg:items-start' : ''}`}>
      <div>
        <p class="font-display text-[11px] uppercase tracking-[0.28em] text-warm-gold">{eyebrow}</p>
        <h1 class="mt-5 break-words font-display text-[2.85rem] leading-none font-bold text-white sm:text-6xl lg:text-7xl">{title}</h1>
        <p class="mt-7 max-w-3xl text-lg leading-8 text-white/65 sm:text-xl">{summary}</p>
      </div>

      {image ? (
        <div class="overflow-hidden border border-white/10 bg-white/3">
          <img src={image} alt={title} class="aspect-[4/3] h-full w-full object-cover" />
        </div>
      ) : null}
    </section>

    {details.length ? (
      <section class="mt-10 grid gap-4 border-y border-white/8 py-6 sm:grid-cols-2 xl:grid-cols-4">
        {details.map((item) => (
          <div>
            <div class="font-display text-[10px] uppercase tracking-[0.24em] text-accent-blue">{item.label}</div>
            <div class="mt-2 text-base leading-7 text-white/72">{item.value}</div>
          </div>
        ))}
      </section>
    ) : null}

    <article class="markdown-prose mt-12 max-w-4xl">
      <slot />
    </article>
  </main>
</SiteLayout>
