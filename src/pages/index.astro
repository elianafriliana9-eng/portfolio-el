---
import HeroShell from '../components/HeroShell';
import MissionsSection from '../components/MissionsSection';
import DiscoverySection from '../components/DiscoverySection';
import StatsSection from '../components/StatsSection';
import DepartureSection from '../components/DepartureSection';
import FooterSection from '../components/FooterSection';
import {
  discovery,
  footerDirectory,
  footerMeta,
  footerPolicies,
  heroContent,
  heroLeftNav,
  heroRightNav,
  launches,
  missions,
  mobileNav,
  nextDeparture,
  spectrumBars,
  stats,
} from '../data/site';
import '../styles/global.css';
---

<html lang="en" class="bg-page-bg">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="AEON Space Agency is a fictional government-backed deep space exploration agency focused on missions, discovery, and next-generation science."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700;800;900&family=Space+Grotesk:wght@300;400;500;700&display=swap"
    />
    <title>AEON Space Agency</title>
  </head>
  <body class="bg-page-bg font-body text-white antialiased">
    <main class="overflow-x-hidden">
      <HeroShell
        client:load
        content={heroContent}
        leftNav={heroLeftNav}
        mobileNav={mobileNav}
        rightNav={heroRightNav}
      />
      <MissionsSection client:visible missions={missions} />
      <DiscoverySection client:visible bars={spectrumBars} content={discovery} />
      <StatsSection client:visible stats={stats} />
      <DepartureSection client:visible content={nextDeparture} launches={launches} />
      <FooterSection
        client:visible
        directory={footerDirectory}
        meta={footerMeta}
        policies={footerPolicies}
      />
    </main>
  </body>
</html>
