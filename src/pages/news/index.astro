---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getNewsEntries, getReadingTimeLabel } from '../../lib/content';
import { formatLongDate } from '../../lib/format';

const newsEntries = await getNewsEntries();
const [leadStory, ...otherStories] = newsEntries;
---

<SiteLayout
  title="AEON News"
  description="Agency news, mission updates, and operational briefings from AEON Space Agency."
>
  <main class="mx-auto max-w-7xl px-6 py-16 sm:px-8 sm:py-20 lg:px-12 lg:py-24">
    <section class="max-w-4xl">
      <p class="font-display text-[11px] uppercase tracking-[0.28em] text-accent-blue">News Desk</p>
      <h1 class="mt-5 font-display text-5xl leading-none font-bold text-white sm:text-6xl lg:text-7xl">Agency News</h1>
      <p class="mt-7 max-w-3xl text-lg leading-8 text-white/65 sm:text-xl">
        Timed dispatches from mission control, the science directorate, and AEON's public network.
      </p>
    </section>

    {leadStory ? (
      <a
        href={`/news/${leadStory.id}/`}
        class="group relative isolate mt-14 block overflow-hidden border border-white/10 bg-white/[0.03]"
      >
        <img src={leadStory.data.image} alt={leadStory.data.title} class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-[1.03]" />
        <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(5,8,12,0.12),rgba(5,8,12,0.58)_42%,rgba(5,8,12,0.94))]" />
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_18%_18%,rgba(74,158,255,0.28),transparent_28%),radial-gradient(circle_at_78%_24%,rgba(240,192,112,0.14),transparent_22%)]" />

        <div class="relative z-10 flex min-h-[430px] items-end p-8 sm:min-h-[520px] sm:p-10 lg:min-h-[620px] lg:p-14">
          <div class="max-w-4xl">
            <div class="flex flex-wrap items-center gap-3 text-sm text-white/62">
              <span class="font-display text-[10px] uppercase tracking-[0.24em] text-warm-gold">{leadStory.data.desk}</span>
              <span>•</span>
              <span>{formatLongDate(leadStory.data.publishedAt)}</span>
              <span>•</span>
              <span>{getReadingTimeLabel(leadStory.body)}</span>
            </div>
            <h2 class="mt-6 max-w-4xl font-display text-[2.9rem] leading-[0.92] text-white sm:text-[3.6rem] lg:text-[4.8rem]">
              {leadStory.data.title}
            </h2>
            <p class="mt-6 max-w-3xl text-[1.08rem] leading-8 text-white/76 sm:text-[1.16rem]">
              {leadStory.data.summary}
            </p>
            <div class="mt-8 text-sm text-white/58">By {leadStory.data.author}</div>
            <span class="mt-10 inline-flex items-center gap-3 font-display text-[11px] uppercase tracking-[0.24em] text-accent-blue transition-colors duration-300 group-hover:text-white">
              Open dispatch <span aria-hidden="true">→</span>
            </span>
          </div>
        </div>
      </a>
    ) : null}

    {otherStories.length ? (
      <section class="mt-10 grid gap-6 lg:grid-cols-2">
        {otherStories.map((entry) => (
          <a
            href={`/news/${entry.id}/`}
            class="group overflow-hidden border border-white/10 bg-white/[0.03] transition-colors duration-300 hover:border-accent-blue/50"
          >
            <img src={entry.data.image} alt={entry.data.title} class="aspect-[16/9] w-full object-cover" />
            <div class="p-7 sm:p-8">
              <div class="flex flex-wrap items-center gap-3 text-sm text-white/48">
                <span class="font-display text-[10px] uppercase tracking-[0.24em] text-warm-gold">{entry.data.desk}</span>
                <span>•</span>
                <span>{formatLongDate(entry.data.publishedAt)}</span>
                <span>•</span>
                <span>{getReadingTimeLabel(entry.body)}</span>
              </div>
              <h2 class="mt-5 font-display text-[2rem] leading-none text-white">{entry.data.title}</h2>
              <p class="mt-5 text-[1.02rem] leading-8 text-white/68">{entry.data.summary}</p>
              <div class="mt-8 text-sm text-white/48">By {entry.data.author}</div>
              <span class="mt-8 inline-flex items-center gap-3 font-display text-[11px] uppercase tracking-[0.24em] text-white/55 transition-colors duration-300 group-hover:text-accent-blue">
                Read story <span aria-hidden="true">→</span>
              </span>
            </div>
          </a>
        ))}
      </section>
    ) : null}
  </main>
</SiteLayout>
