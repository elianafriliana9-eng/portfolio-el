---
import { render } from 'astro:content';

import EditorialEntryLayout from '../../layouts/EditorialEntryLayout.astro';
import { getNewsEntries, getReadingTimeLabel } from '../../lib/content';
import { formatLongDate } from '../../lib/format';

export async function getStaticPaths() {
  const newsEntries = await getNewsEntries();
  return newsEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<EditorialEntryLayout
  title={entry.data.title}
  eyebrow={entry.data.desk}
  summary={entry.data.summary}
  image={entry.data.image}
  backHref="/news/"
  backLabel="All articles"
  details={[
    { label: 'Published', value: formatLongDate(entry.data.publishedAt) },
    { label: 'Reading Time', value: getReadingTimeLabel(entry.body) },
    { label: 'Author', value: entry.data.author },
    { label: 'Category', value: entry.data.desk },
  ]}
>
  <Content />
</EditorialEntryLayout>
