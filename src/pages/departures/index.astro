---
import CollectionIndexLayout from '../../layouts/CollectionIndexLayout.astro';
import { formatLaunchTime, formatLongDate } from '../../lib/format';
import { getDepartureEntries } from '../../lib/content';

const departures = await getDepartureEntries();
---

<CollectionIndexLayout
  title="Skills Portfolio"
  eyebrow="Skill Categories"
  intro="Overview of my technical, design, and professional skills."
  description="Browse my technical and soft skills."
>
  <div class="grid gap-6 lg:grid-cols-2">
    {departures.map((departure) => (
      <a
        href={`/departures/${departure.id}/`}
        class="group overflow-hidden border border-white/10 bg-white/3 transition-colors duration-300 hover:border-accent-blue/50"
      >
        <img src={departure.data.image} alt={departure.data.title} class="aspect-[4/3] w-full object-cover" />
        <div class="p-7 sm:p-8">
          <h2 class="break-words font-display text-[2rem] leading-none text-white">{departure.data.title}</h2>
          <p class="mt-4 text-[1.02rem] text-white/72">{departure.data.detail}</p>
          <dl class="mt-8 grid gap-4 text-sm text-white/54">
            <div>
              <dt class="font-display text-[10px] uppercase tracking-[0.22em] text-accent-blue">Category</dt>
              <dd class="mt-2 leading-6">{departure.data.launchSite}</dd>
            </div>
            <div>
              <dt class="font-display text-[10px] uppercase tracking-[0.22em] text-accent-blue">Proficiency Level</dt>
              <dd class="mt-2 leading-6">{departure.data.missionWindow}</dd>
            </div>
          </dl>
          <span class="mt-8 inline-flex items-center gap-3 font-display text-[11px] uppercase tracking-[0.24em] text-white/55 transition-colors duration-300 group-hover:text-accent-blue">
            View details <span aria-hidden="true">→</span>
          </span>
        </div>
      </a>
    ))}
  </div>
</CollectionIndexLayout>
